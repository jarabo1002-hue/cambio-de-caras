{
  "version": 2,
  "name": "cambio-de-caras-frontend",
  "builds": [
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://face-swap-app-9dz7.onrender.com/api/$1",
      "headers": {
        "x-vercel-rewrite": "1"
      }
    },
    {
      "src": "/results/(.*)",
      "dest": "https://face-swap-app-9dz7.onrender.com/results/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
